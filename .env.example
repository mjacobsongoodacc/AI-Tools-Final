# Analysis → n8n: copy "Production URL" from your Webhook node (path includes /webhook/).
# Do NOT use the workflow editor URL (…/workflow/…).
#
# Example:
# VITE_N8N_WEBHOOK_URL=https://mjacobsongodacc.app.n8n.cloud/webhook/diligence

VITE_N8N_WEBHOOK_URL=

# Supabase project URL (Settings → API → Project URL).
VITE_SUPABASE_URL=

# Supabase anon (publishable) key — Auth + polling `dilligencetable` with RLS as the signed-in user.
VITE_SUPABASE_ANON_KEY=

# Optional: max ms to wait for Supabase row (default 600000 = 10 min). Min 30000.
# VITE_ANALYSIS_POLL_TIMEOUT_MS=900000

# Optional: upload webhook fetch timeout (ms). Unset = no client timeout on upload.
# VITE_DOCUMENT_UPLOAD_TIMEOUT_MS=120000
